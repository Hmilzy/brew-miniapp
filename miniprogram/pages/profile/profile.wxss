.profile-page {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 顶部用户信息区 */
.user-header {
  background: #111;
  padding: 80rpx 48rpx 60rpx;
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #333;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-icon {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #aaa;
  border-radius: 50%;
  position: relative;
}

.avatar-icon::after {
  content: '';
  position: absolute;
  top: 44rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 64rpx;
  height: 36rpx;
  border: 4rpx solid #aaa;
  border-top: none;
  border-radius: 0 0 32rpx 32rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.level-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  background: rgba(255, 215, 0, 0.15);
  border: 1rpx solid rgba(255, 215, 0, 0.4);
  border-radius: 20rpx;
  align-self: flex-start;
}

.level-text {
  font-size: 22rpx;
  color: #ffd700;
  font-weight: 500;
}

/* 数据概览横条 */
.stats-bar {
  margin: 24rpx 32rpx 0;
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx 0;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #111;
}

.stat-label {
  font-size: 24rpx;
  color: #888;
}

.stat-divider {
  width: 1rpx;
  height: 56rpx;
  background: #e8e8e8;
}

/* 功能入口列表 */
.menu-list {
  margin: 24rpx 32rpx 0;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 36rpx 32rpx;
  position: relative;
}

.menu-item:not(:last-child)::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 96rpx;
  right: 32rpx;
  height: 1rpx;
  background: #f0f0f0;
}

.menu-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

/* 订单图标 */
.icon-order {
  width: 30rpx;
  height: 28rpx;
  border: 3rpx solid #333;
  border-radius: 4rpx;
  position: relative;
}

.icon-order::before {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 5rpx;
  right: 5rpx;
  height: 3rpx;
  background: #333;
  box-shadow: 0 8rpx 0 #333;
}

/* 地址图标 */
.icon-address {
  width: 22rpx;
  height: 28rpx;
  border: 3rpx solid #333;
  border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
  position: relative;
}

.icon-address::before {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  border: 3rpx solid #333;
}

/* 兑换图标 */
.icon-exchange {
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid #333;
  border-radius: 50%;
  position: relative;
}

.icon-exchange::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 14rpx;
  height: 3rpx;
  background: #333;
}

.icon-exchange::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 3rpx;
  height: 14rpx;
  background: #333;
}

.menu-title {
  flex: 1;
  font-size: 30rpx;
  color: #222;
  font-weight: 500;
}

.menu-arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid #ccc;
  border-right: 3rpx solid #ccc;
  transform: rotate(45deg);
}
