.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 300rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.empty-sub {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}

.order-list {
  padding-bottom: 40rpx;
}

.order-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-id {
  font-size: 28rpx;
  color: #222;
  font-weight: 600;
}

.order-status {
  font-size: 24rpx;
  color: #E67E22;
  font-weight: 500;
  background: #fff8f0;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}

.order-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.order-items {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.order-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.oi-name {
  font-size: 28rpx;
  color: #333;
}

.oi-spec {
  font-size: 22rpx;
  color: #999;
}

.order-footer {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  justify-content: flex-end;
}

.order-total {
  font-size: 30rpx;
  color: #E67E22;
  font-weight: 600;
}
