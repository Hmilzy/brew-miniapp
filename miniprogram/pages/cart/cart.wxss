.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 300rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.empty-sub {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}

.cart-list {
  padding: 24rpx;
}

.cart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.cart-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
}

.cart-clear {
  font-size: 26rpx;
  color: #999;
}

.cart-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 30rpx;
  color: #222;
  font-weight: 500;
  display: block;
}

.item-spec {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.item-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.item-price {
  font-size: 30rpx;
  color: #E67E22;
  font-weight: 600;
}

.quantity-control {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.qty-btn {
  width: 48rpx;
  height: 48rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #333;
}

.qty-num {
  margin: 0 20rpx;
  font-size: 28rpx;
  font-weight: 500;
  min-width: 32rpx;
  text-align: center;
}

.bottom-bar {
  position: fixed;
  bottom: calc(env(safe-area-inset-bottom) + 50px);
  left: 0;
  right: 0;
  height: 110rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.total-section {
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 12rpx;
}

.total-price {
  font-size: 40rpx;
  color: #E67E22;
  font-weight: 700;
}

.submit-btn {
  background: #E67E22;
  color: #fff;
  padding: 20rpx 56rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
}
