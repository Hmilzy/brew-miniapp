.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.address-list {
  padding: 20rpx 24rpx;
}

.address-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 2rpx solid transparent;
}

.address-item.default {
  border-color: #1a1a1a;
}

.address-main {
  flex: 1;
  min-width: 0;
}

.address-user {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.address-phone {
  font-size: 26rpx;
  color: #666;
  margin-left: 20rpx;
}

.address-tag {
  font-size: 20rpx;
  color: #666;
  background: #f0f0f0;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  margin-left: 16rpx;
}

.address-text {
  font-size: 26rpx;
  color: #666;
  display: block;
}

.address-check {
  width: 44rpx;
  height: 44rpx;
  background: #1a1a1a;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.empty-hint {
  padding: 120rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

/* 底部按钮 */
.add-btn-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.add-btn {
  height: 88rpx;
  background: #1a1a1a;
  color: #fff;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
}

/* 表单弹窗 */
.form-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 300;
}

.form-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  z-index: 301;
}

.form-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.form-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  height: 80rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}

.tag-options {
  display: flex;
  gap: 16rpx;
}

.tag-opt {
  padding: 12rpx 28rpx;
  border: 2rpx solid #eee;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
  background: #fafafa;
}

.tag-opt.active {
  border-color: #1a1a1a;
  color: #1a1a1a;
  background: #f5f5f5;
  font-weight: 500;
}

.form-submit {
  margin-top: 40rpx;
  height: 88rpx;
  background: #1a1a1a;
  color: #fff;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
}
