<view class="profile-page">
  <!-- 顶部用户信息区 -->
  <view class="user-header">
    <view class="avatar">
      <view class="avatar-icon"></view>
    </view>
    <view class="user-info">
      <text class="nickname">BREW会员</text>
      <view class="level-tag">
        <text class="level-text">黑金会员</text>
      </view>
    </view>
  </view>

  <!-- 数据概览横条 -->
  <view class="stats-bar">
    <view class="stat-item" bindtap="goToPoints">
      <text class="stat-value">{{points}}</text>
      <text class="stat-label">积分</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="onCouponTap">
      <text class="stat-value">3</text>
      <text class="stat-label">优惠券</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="goToOrders">
      <text class="stat-value">{{orderCount}}</text>
      <text class="stat-label">订单</text>
    </view>
  </view>

  <!-- 功能入口列表 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goToOrders">
      <view class="menu-icon">
        <view class="icon-order"></view>
      </view>
      <text class="menu-title">我的订单</text>
      <view class="menu-arrow"></view>
    </view>
    <view class="menu-item" bindtap="goToAddress">
      <view class="menu-icon">
        <view class="icon-address"></view>
      </view>
      <text class="menu-title">收货地址</text>
      <view class="menu-arrow"></view>
    </view>
    <view class="menu-item" bindtap="goToExchange">
      <view class="menu-icon">
        <view class="icon-exchange"></view>
      </view>
      <text class="menu-title">兑换记录</text>
      <view class="menu-arrow"></view>
    </view>
  </view>
</view>
