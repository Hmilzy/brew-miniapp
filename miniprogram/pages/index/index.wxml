<view class="page">
  <!-- 顶部：门店选择 + 自提/外送切换 -->
  <view class="top-bar">
    <view class="store-info" bindtap="onStoreTap">
      <view class="store-icon">
        <view class="location-dot"></view>
      </view>
      <view class="store-detail">
        <view class="store-name-row">
          <text class="store-name">{{currentStore.name}}</text>
          <text class="store-arrow">▾</text>
        </view>
        <text class="store-meta">{{currentStore.distance}} · {{currentStore.address}}</text>
      </view>
    </view>
    <view class="mode-tabs">
      <view class="mode-tab {{orderMode === 'pickup' ? 'active' : ''}}" bindtap="onModeTap" data-mode="pickup">自提</view>
      <view class="mode-tab {{orderMode === 'delivery' ? 'active' : ''}}" bindtap="onModeTap" data-mode="delivery">外送</view>
    </view>
  </view>

  <!-- Banner 轮播图 -->
  <view class="banner-wrap">
    <swiper
      class="banner-swiper"
      autoplay
      circular
      interval="3000"
      duration="600"
      previous-margin="24rpx"
      next-margin="24rpx"
      bindchange="onBannerChange"
    >
      <swiper-item wx:for="{{banners}}" wx:key="id">
        <view class="banner-card {{currentBanner === index ? 'active' : ''}}">
          <image class="banner-img" src="{{item.image}}" mode="aspectFill"></image>
          <view class="banner-overlay">
            <text class="banner-title">{{item.title}}</text>
          </view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <view class="search-icon"></view>
      <input
        class="search-input"
        placeholder="搜索饮品"
        placeholder-class="search-placeholder"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        confirm-type="search"
      />
      <view class="search-clear" wx:if="{{searchKeyword}}" bindtap="onSearchClear">✕</view>
    </view>
  </view>

  <!-- 主体：左侧分类 + 右侧商品 -->
  <view class="main">
    <scroll-view class="sidebar" scroll-y wx:if="{{!searchKeyword}}">
      <view
        class="sidebar-item {{currentCategory === item ? 'active' : ''}}"
        wx:for="{{categories}}"
        wx:key="*this"
        data-category="{{item}}"
        bindtap="onCategoryTap"
      >{{item}}</view>
    </scroll-view>

    <scroll-view
      class="product-list {{searchKeyword ? 'full-width' : ''}}"
      scroll-y
      scroll-into-view="{{scrollToView}}"
      scroll-with-animation
      bindscroll="onProductScroll"
      wx:if="{{!searchKeyword}}"
    >
      <view
        class="category-section"
        wx:for="{{groupedProducts}}"
        wx:key="category"
        id="section-{{index}}"
      >
        <view class="section-title">{{item.category}}</view>
        <view class="product-card" wx:for="{{item.items}}" wx:for-item="prod" wx:key="id" data-id="{{prod.id}}" bindtap="onProductTap">
          <view class="product-img"></view>
          <view class="product-info">
            <text class="product-name">{{prod.name}}</text>
            <text class="product-desc">{{prod.description}}</text>
            <view class="product-bottom">
              <text class="product-price">¥{{prod.price}}</text>
              <view class="quick-add" catchtap="onQuickAdd" data-id="{{prod.id}}">+</view>
            </view>
          </view>
        </view>
      </view>
      <!-- 底部占位，让最后一个商品可以滑到购物车上方 -->
      <view class="list-bottom-spacer"></view>
    </scroll-view>

    <!-- 搜索结果列表 -->
    <scroll-view class="product-list full-width" scroll-y wx:if="{{searchKeyword}}">
      <view class="search-result-hint" wx:if="{{searchResults.length}}">找到 {{searchResults.length}} 个商品</view>
      <view class="product-card" wx:for="{{searchResults}}" wx:key="id" data-id="{{item.id}}" bindtap="onProductTap">
        <view class="product-img"></view>
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <text class="product-desc">{{item.description}}</text>
          <view class="product-bottom">
            <text class="product-price">¥{{item.price}}</text>
            <view class="quick-add" catchtap="onQuickAdd" data-id="{{item.id}}">+</view>
          </view>
        </view>
      </view>
      <view class="search-empty" wx:if="{{!searchResults.length}}">
        <text class="search-empty-text">没有找到相关商品</text>
      </view>
      <view class="list-bottom-spacer"></view>
    </scroll-view>
  </view>

  <!-- 底部购物车浮窗 -->
  <view class="cart-bar" bindtap="goToCart">
    <view class="cart-left">
      <view class="cart-badge">{{cartCount}}</view>
      <text class="cart-label">购物车</text>
    </view>
    <view class="cart-right" wx:if="{{cartCount > 0}}">
      <text class="cart-total">¥{{cartTotal}}</text>
      <view class="cart-btn">去结算</view>
    </view>
    <view class="cart-right" wx:else>
      <text class="cart-empty-hint">去选购</text>
    </view>
  </view>

  <!-- 商品详情弹窗 -->
  <view class="detail-mask" wx:if="{{showDetail}}" bindtap="onMaskTap"></view>
  <view class="detail-popup" wx:if="{{showDetail}}">
    <view class="detail-header">
      <view class="detail-img"></view>
      <view class="detail-info">
        <text class="detail-name">{{currentProduct.name}}</text>
        <text class="detail-desc">{{currentProduct.description}}</text>
        <text class="detail-price">¥{{currentProduct.price}}</text>
      </view>
      <view class="detail-close" bindtap="onCloseDetail">✕</view>
    </view>

    <view class="spec-section">
      <view class="spec-title">杯型</view>
      <view class="spec-options">
        <view class="spec-opt {{specSize === '中杯' ? 'selected' : ''}}" data-value="中杯" bindtap="onSizeChange">中杯</view>
        <view class="spec-opt {{specSize === '大杯' ? 'selected' : ''}}" data-value="大杯" bindtap="onSizeChange">大杯 +4</view>
      </view>
    </view>

    <view class="spec-section">
      <view class="spec-title">温度</view>
      <view class="spec-options">
        <view class="spec-opt {{specTemp === '冰' ? 'selected' : ''}}" data-value="冰" bindtap="onTempChange">冰</view>
        <view class="spec-opt {{specTemp === '热' ? 'selected' : ''}}" data-value="热" bindtap="onTempChange">热</view>
      </view>
    </view>

    <view class="spec-section">
      <view class="spec-title">糖度</view>
      <view class="spec-options">
        <view class="spec-opt {{specSugar === '无糖' ? 'selected' : ''}}" data-value="无糖" bindtap="onSugarChange">无糖</view>
        <view class="spec-opt {{specSugar === '少糖' ? 'selected' : ''}}" data-value="少糖" bindtap="onSugarChange">少糖</view>
        <view class="spec-opt {{specSugar === '正常' ? 'selected' : ''}}" data-value="正常" bindtap="onSugarChange">正常</view>
        <view class="spec-opt {{specSugar === '多糖' ? 'selected' : ''}}" data-value="多糖" bindtap="onSugarChange">多糖</view>
      </view>
    </view>

    <view class="detail-add-btn" bindtap="onAddToCart">加入购物车</view>
  </view>

  <!-- 门店选择弹窗 -->
  <view class="store-mask" wx:if="{{showStorePopup}}" bindtap="onStorePopupClose"></view>
  <view class="store-popup {{showStorePopup ? 'show' : ''}}">
    <view class="store-popup-header">
      <text class="store-popup-title">选择门店</text>
      <view class="store-popup-close" bindtap="onStorePopupClose">✕</view>
    </view>
    <scroll-view class="store-list" scroll-y>
      <view
        class="store-list-item {{currentStore.id === item.id ? 'selected' : ''}}"
        wx:for="{{stores}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onStoreSelect"
      >
        <view class="store-list-info">
          <text class="store-list-name">{{item.name}}</text>
          <text class="store-list-addr">{{item.address}}</text>
        </view>
        <text class="store-list-dist">{{item.distance}}</text>
      </view>
    </scroll-view>
  </view>
</view>
