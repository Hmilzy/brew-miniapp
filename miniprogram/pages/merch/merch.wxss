.merch-page {
  height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 顶部导航 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  height: 88rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
  flex-shrink: 0;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  width: 18rpx;
  height: 18rpx;
  border-left: 3rpx solid #222;
  border-bottom: 3rpx solid #222;
  transform: rotate(45deg);
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111;
}

.nav-cart {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.cart-icon {
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid #222;
  border-radius: 0 0 6rpx 6rpx;
  position: relative;
}

.cart-icon::before {
  content: '';
  position: absolute;
  top: -12rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 18rpx;
  height: 12rpx;
  border: 3rpx solid #222;
  border-bottom: none;
  border-radius: 10rpx 10rpx 0 0;
}

.cart-badge {
  position: absolute;
  top: 6rpx;
  right: 2rpx;
  min-width: 28rpx;
  height: 28rpx;
  background: #222;
  color: #fff;
  font-size: 18rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

/* 分类筛选 */
.category-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  gap: 20rpx;
  background: #fff;
  flex-shrink: 0;
}

.category-item {
  padding: 14rpx 36rpx;
  border-radius: 32rpx;
  background: #f0f0f0;
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
  transition: all 0.2s;
}

.category-item.active {
  background: #222;
  color: #fff;
}

/* 商品网格 */
.product-grid-scroll {
  flex: 1;
  overflow: hidden;
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 24rpx 24rpx 0;
  gap: 20rpx;
}

.product-card {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-img-wrap {
  position: relative;
  width: 100%;
  height: 320rpx;
}

.card-img {
  width: 100%;
  height: 100%;
  filter: grayscale(60%);
}

.card-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.tag-limited {
  background: #222;
  color: #fff;
}

.tag-new {
  background: #fff;
  color: #222;
  border: 2rpx solid #222;
}

.card-info {
  padding: 20rpx 20rpx 24rpx;
}

.card-name {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #222;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-price {
  display: block;
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #111;
}

.grid-bottom-spacer {
  height: 40rpx;
}

/* 详情弹窗 */
.detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.detail-popup {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 201;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.detail-popup.show {
  transform: translateY(0);
}

.detail-header {
  position: relative;
  width: 100%;
  height: 360rpx;
  flex-shrink: 0;
}

.detail-img {
  width: 100%;
  height: 100%;
  border-radius: 32rpx 32rpx 0 0;
  filter: grayscale(50%);
}

.detail-close {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-x {
  width: 24rpx;
  height: 24rpx;
  position: relative;
}

.close-x::before,
.close-x::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 0;
  width: 100%;
  height: 3rpx;
  background: #fff;
  border-radius: 2rpx;
}

.close-x::before {
  transform: rotate(45deg);
}

.close-x::after {
  transform: rotate(-45deg);
}

.detail-body {
  padding: 32rpx;
  flex: 1;
  overflow-y: auto;
}

.detail-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.detail-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #111;
}

.detail-tag {
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.detail-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #888;
  line-height: 1.5;
}

.detail-price {
  display: block;
  margin-top: 16rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: #111;
}

/* 规格选择 */
.spec-section {
  margin-top: 32rpx;
}

.spec-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.spec-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.spec-item {
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
  font-size: 26rpx;
  color: #444;
  background: #fafafa;
  transition: all 0.2s;
}

.spec-item.active {
  border-color: #222;
  background: #222;
  color: #fff;
}

/* 底部按钮 */
.detail-footer {
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #eee;
  flex-shrink: 0;
}

.add-cart-btn {
  width: 100%;
  height: 88rpx;
  background: #222;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
