.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.main {
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* 左侧分类 */
.sidebar {
  width: 176rpx;
  background: #fff;
  height: 100%;
  padding-top: 20rpx;
}

.sidebar-item {
  padding: 30rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #666;
  position: relative;
}

.sidebar-item.active {
  color: #E67E22;
  font-weight: 600;
  background: #f5f5f5;
}

.sidebar-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 40rpx;
  background: #E67E22;
  border-radius: 0 3rpx 3rpx 0;
}

/* 右侧商品列表 */
.product-list {
  flex: 1;
  height: 100%;
  padding: 20rpx 24rpx;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  padding: 20rpx 0 12rpx;
}

.product-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.product-img {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #d4a574, #8b6f47);
  border-radius: 12rpx;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
}

.product-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.product-price {
  font-size: 32rpx;
  color: #E67E22;
  font-weight: 600;
}

.quick-add {
  width: 48rpx;
  height: 48rpx;
  background: #E67E22;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
}

/* 底部购物车 */
.cart-bar {
  position: fixed;
  bottom: calc(env(safe-area-inset-bottom) + 50px);
  left: 24rpx;
  right: 24rpx;
  height: 96rpx;
  background: #222;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  z-index: 100;
}

.cart-left {
  display: flex;
  align-items: center;
}

.cart-badge {
  width: 44rpx;
  height: 44rpx;
  background: #E67E22;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
}

.cart-label {
  color: #fff;
  margin-left: 16rpx;
  font-size: 28rpx;
}

.cart-right {
  display: flex;
  align-items: center;
}

.cart-total {
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  margin-right: 24rpx;
}

.cart-btn {
  background: #E67E22;
  color: #fff;
  padding: 16rpx 36rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}

/* 详情弹窗 */
.detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.detail-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  z-index: 201;
}

.detail-header {
  display: flex;
  position: relative;
}

.detail-img {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #d4a574, #8b6f47);
  border-radius: 12rpx;
  flex-shrink: 0;
}

.detail-info {
  margin-left: 24rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.detail-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #222;
}

.detail-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.detail-price {
  font-size: 34rpx;
  color: #E67E22;
  font-weight: 600;
  margin-top: 12rpx;
}

.detail-close {
  position: absolute;
  right: 0;
  top: 0;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999;
}

/* 规格选择 */
.spec-section {
  margin-top: 32rpx;
}

.spec-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.spec-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.spec-opt {
  padding: 14rpx 32rpx;
  border: 2rpx solid #eee;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
  background: #fafafa;
}

.spec-opt.selected {
  border-color: #E67E22;
  color: #E67E22;
  background: #fff8f0;
}

.detail-add-btn {
  margin-top: 40rpx;
  height: 88rpx;
  background: #E67E22;
  color: #fff;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
}
