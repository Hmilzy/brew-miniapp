.home-page {
  height: 100vh;
  position: relative;
  overflow: hidden;
}

/* 背景图 */
.hero-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  background: linear-gradient(180deg, #1a0e05 0%, #3d2415 30%, #5c3a20 50%, #8b5e3c 70%, #d4a574 100%);
  z-index: 0;
}

/* 可滑动内容 */
.content-scroll {
  position: relative;
  z-index: 1;
  height: 100vh;
}

/* 上半区留白 */
.hero-spacer {
  height: 55vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 服务选择卡片 */
.service-card {
  margin: 0 32rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 0;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  display: flex;
  align-items: center;
}

.service-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.service-icon {
  font-size: 48rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff8f0;
  border-radius: 50%;
}

.service-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
}

.service-sub {
  font-size: 22rpx;
  color: #999;
}

.service-divider-v {
  width: 1rpx;
  height: 80rpx;
  background: #f0f0f0;
}

/* 活动卡片 */
.activity-card {
  margin: 24rpx 32rpx 0;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
}

.activity-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.activity-icon {
  font-size: 40rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff8f0;
  border-radius: 50%;
}

.activity-title {
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
}

/* 上滑提示 */
.scroll-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 48rpx;
  margin-bottom: 32rpx;
}

.hint-arrow {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  animation: bounce 1.5s ease-in-out infinite;
}

.hint-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 8rpx;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

/* 探索区域 */
.explore-section {
  margin: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.explore-item {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.explore-img {
  width: 100%;
  height: 300rpx;
}

.explore-img.img-1 {
  background: linear-gradient(135deg, #f6d365, #fda085);
}

.explore-img.img-2 {
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.explore-img.img-3 {
  background: linear-gradient(135deg, #43e97b, #38f9d7);
}

.explore-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  padding: 20rpx 24rpx 0;
}

.explore-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 24rpx 24rpx;
}

/* 底部留白 */
.bottom-spacer {
  height: 160rpx;
}

/* 悬浮 Tab 栏 */
.float-tab {
  position: fixed;
  bottom: calc(32rpx + env(safe-area-inset-bottom));
  left: 48rpx;
  right: 48rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  z-index: 100;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 16rpx;
  border-radius: 32rpx;
  gap: 4rpx;
}

.tab-icon {
  font-size: 36rpx;
  line-height: 1.2;
}

.tab-item.active .tab-icon {
  transform: scale(1.1);
}

.tab-item.active .tab-label {
  color: #E67E22;
  font-weight: 600;
}

.tab-label {
  font-size: 20rpx;
  color: #666;
  font-weight: 500;
}
